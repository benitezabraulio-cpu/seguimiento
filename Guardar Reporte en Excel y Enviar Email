name: Guardar Reporte en Excel y Enviar Email
on:
  issues:
    types: [opened]

jobs:
  build:
    if: contains(github.event.issue.labels.*.name, 'seguimiento')
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repositorio
        uses: actions/checkout@v3

      - name: Extraer datos del formulario
        run: |
          # Script simple para extraer los campos y guardarlos en un CSV (compatible con Excel)
          echo "${{ github.event.issue.created_at }}, ${{ github.event.issue.user.login }}, Reporte Guardado" >> seguimiento.csv

      - name: Enviar correo a la empresa
        uses: dawidd6/action-send-mail@v3
        with:
          server_address: smtp.gmail.com
          server_port: 465
          username: ${{secrets.MAIL_USERNAME}}
          password: ${{secrets.MAIL_PASSWORD}}
          subject: Nuevo Reporte de Obra - ${{ github.event.issue.title }}
          to: correodelempresa@ejemplo.com
          from: GitHub App Seguimiento
          attachments: seguimiento.csv
